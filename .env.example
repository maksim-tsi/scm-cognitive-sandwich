# ============================================================================
# SCM COGNITIVE SANDWICH - ENVIRONMENT CONFIGURATION
# ============================================================================

# --- 1. EXTERNAL SIMULATION ENVIRONMENT ---
# URL of the deterministic Mock API (maritime-port-sandbox)
# Default is local development. For skz-dev, change to the respective IP.
SANDBOX_API_URL=http://localhost:8000

# --- 2. LLM PROVIDER API KEYS ---
# LangGraph agents will use these to authenticate with the chosen models.
# We will primarily use models with strong JSON/Structured Output capabilities.
GROQ_API_KEY=''
MISTRAL_API_KEY=''
GOOGLE_API_KEY=''

# --- 3. OBSERVABILITY (LangSmith / Arize Phoenix) ---
# Optional: To trace the LangGraph execution steps visually
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=''
LANGCHAIN_PROJECT='scm-cognitive-sandwich-idwl'

# --- OBSERVABILITY (Arize Phoenix on skz-dev-lv) ---
PHOENIX_COLLECTOR_ENDPOINT=http://192.168.107.172:6006/v1/traces
PHOENIX_PROJECT_NAME=scm-cognitive-sandwich-idwl

# ============================================================================
# PHASE 2: YAAM INFRASTRUCTURE (skz-dev / skz-data)
# ============================================================================
# Note: These are not strictly required for the baseline IDWL mock run, 
# but will be used when YAAM is fully connected via the .whl package.

# --- PostgreSQL (L2 Storage) ---
POSTGRES_USER='pgadmin'
POSTGRES_PASSWORD=''
POSTGRES_DB='mas_memory'
POSTGRES_HOST=192.168.107.187
POSTGRES_PORT=5432

# --- Redis (L1 Working Memory) ---
REDIS_HOST=192.168.107.172
REDIS_PORT=6379

# --- Neo4j (Lineage Truth & Auditability) ---
NEO4J_URI=bolt://192.168.107.187:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=''

# --- Typesense (L4 Semantic Memory) ---
TYPESENSE_URL=http://192.168.107.187:8108
TYPESENSE_API_KEY=''